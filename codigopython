from anthropic import Anthropic
import gspread
from oauth2client.service_account import ServiceAccountCredentials
import json
import os

# ==========================================
# CONFIGURAÇÃO CLAUDE
# ==========================================

client = Anthropic(
    api_key=os.getenv("ANTHROPIC_API_KEY")
)

# ==========================================
# CONFIGURAÇÃO GOOGLE SHEETS
# ==========================================

scope = [
    "https://spreadsheets.google.com/feeds",
    "https://www.googleapis.com/auth/drive"
]

creds = ServiceAccountCredentials.from_json_keyfile_name(
    "credenciais.json",
    scope
)

google_client = gspread.authorize(creds)

# Nome da planilha
planilha = google_client.open("NomedaPlanilha").sheet1

# ==========================================
# ENTRADA DE DADOS
# ==========================================

print("=" * 50)
print("SISTEMA JURÍDICO COM IA")
print("=" * 50)

print("\nCole TODOS os clientes abaixo.")
print("Digite FIM para finalizar.\n")

linhas = []

while True:
    linha = input()

    if linha.strip().upper() == "FIM":
        break

    if linha.strip() != "":
        linhas.append(linha)

texto = "\n".join(linhas)

# ==========================================
# PROMPT PARA IA
# ==========================================

prompt = f"""
Você é um assistente de um escritório de advocacia.

Extraia informações dos textos abaixo e retorne SOMENTE um JSON válido.

FORMATO OBRIGATÓRIO:
[
  {{
    "nome": "",
    "cpf": "",
    "processo": "",
    "resumo": ""
  }}
]

REGRAS IMPORTANTES:
- Não escreva explicações
- Não use markdown
- Não adicione texto fora do JSON
- Retorne apenas JSON puro

TEXTOS:
{texto}
"""

# ==========================================
# CHAMADA IA
# ==========================================

message = client.messages.create(
    model="claude-sonnet-4-6",
    max_tokens=4000,
    messages=[
        {
            "role": "user",
            "content": prompt
        }
    ]
)

resultado = message.content[0].text

print("\n" + "=" * 50)
print("RESPOSTA DA IA")
print("=" * 50)
print(resultado)

# ==========================================
# LIMPEZA DO JSON
# ==========================================

resultado = resultado.replace("```json", "").replace("```", "").strip()

# ==========================================
# CONVERSÃO SEGURA
# ==========================================

try:
    clientes = json.loads(resultado)
except json.JSONDecodeError:
    print("\n❌ Erro: a IA não retornou um JSON válido.")
    exit()

# ==========================================
# ENVIO PARA GOOGLE SHEETS
# ==========================================

for cliente in clientes:
    nome = cliente.get("nome", "")
    cpf = cliente.get("cpf", "")
    processo = cliente.get("processo", "")
    resumo = cliente.get("resumo", "")

    planilha.append_row([nome, cpf, processo, resumo])

    print(f"✅ Enviado: {nome}")

print("\n🔥 Todos os clientes foram enviados com sucesso!")
